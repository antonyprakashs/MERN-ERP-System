            ],
            "url": {
              "raw": "{{BASE_URL}}/api/users?page=1&search=John",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "search", "value": "John" }
              ]
            }
          }
        },
        {
          "name": "Update User Role/Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Sales Executive\",\n  \"role\": \"Sales\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/users/:userId",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", ":userId"]
            }
          }
        },
        {
          "name": "Delete User Account",
          "request": {
